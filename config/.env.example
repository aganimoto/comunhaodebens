# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cdb_shalom
POSTGRES_USER=cdb_user
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgresql+asyncpg://cdb_user:CHANGE_ME@postgres:5432/cdb_shalom

# Redis
REDIS_URL=redis://redis:6379/0

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5-vl:7b
OLLAMA_FALLBACK_MODEL=qwen2.5:7b
OLLAMA_TEXT_MODEL=qwen3:4b

# OCR — seleção de engine (paddle | tesseract)
OCR_ENGINE=paddle
# Caminho do binário tesseract (vazio = usar PATH do sistema)
TESSERACT_CMD=
# Idiomas do Tesseract (por=português, eng=inglês)
TESSERACT_LANG=por

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON=/run/secrets/google_sa.json
GOOGLE_SPREADSHEET_ID=1wvY1TRVT4EskO50kB1r_8YEBfadqIKdtEMowdoyFFW0

# WhatsApp Service
WHATSAPP_SERVICE_URL=http://whatsapp-service:3000
WHATSAPP_WEBHOOK_SECRET=CHANGE_ME_RANDOM_32_CHARS
WHATSAPP_WEBHOOK_URL=http://backend:8000/api/v1/webhooks/whatsapp

# JWT
JWT_SECRET_KEY=CHANGE_ME_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=8

# App
APP_TIMEZONE=America/Sao_Paulo
SHARED_MEDIA_PATH=/shared/media
SHARED_RELATORIOS_PATH=/shared/relatorios
SHARED_BACKUP_PATH=/shared/backups
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (build-time)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Cache defaults (override via Sheets Configuração)
CACHE_MEMBROS_TTL_MIN=5
CACHE_CONFIG_TTL_SEC=60
LIMIAR_CONFIANCA=0.80
